# Copy this file to `.env` and fill in the values.
# rag.py reads LLM_BASE_URL, LLM_API_KEY, LLM_MODEL (chat) and EMBED_MODEL.
# CHUNK_SIZE / TOP_K are constants at the top of rag.py.

# --- Endpoint — OpenAI-compatible, used for BOTH embeddings and chat ---
# Default: a local Ollama (no key needed). Pull the two models first:
#   ollama serve
#   ollama pull llama3.2
#   ollama pull bge-m3
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2        # chat
EMBED_MODEL=bge-m3        # embeddings

# Internal alternative — a LiteLLM proxy (e.g. an org endpoint behind a VPN).
# Ask internally for the concrete URL and a virtual key (sk-...); never commit a real key.
#   LLM_BASE_URL=http://<llm-proxy-host>:8080/v1
#   LLM_API_KEY=sk-REPLACE_ME
#   LLM_MODEL=marvin-default      # or marvin-documents-candidate
#   EMBED_MODEL=marvin-embed
