# Copy this file to `.env` and adjust. NON-SECRET configuration only.
#
# The API key deliberately does NOT live in .env. Set it once per shell
# session — it stays in the process environment and is never written to disk:
#   .\set-key.ps1            (PowerShell)
#   source set-key.sh        (bash/zsh)
# python-dotenv never overrides existing environment variables, so the
# session key always wins.

# Default: Marvin (LiteLLM proxy, reachable via AKROS VPN only).
# Get a virtual key (sk-...) internally and set it via the script above.
LLM_BASE_URL=http://marvin-backend.akros.ch:8080
LLM_MODEL=marvin-documents-candidate      # chat (alternative: marvin-documents-candidate)
EMBED_MODEL=marvin-embed       # embeddings (BGE-M3)

# Local alternative: Ollama (no key, no VPN). Pull the two models first:
#   ollama serve && ollama pull llama3.2 && ollama pull bge-m3
# then use:
#   LLM_BASE_URL=http://localhost:11434/v1
#   LLM_MODEL=llama3.2
#   EMBED_MODEL=bge-m3

# API Key for marving configured for model access
LLM_API_KEY=sk-*****